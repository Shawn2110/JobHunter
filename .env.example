# JobHunt — environment configuration
#
# Copy this file to `.env` and fill in the one required key —
# ANTHROPIC_API_KEY. Run `python scripts/setup_ai.py` for an
# interactive setup. Everything else has working defaults.
#
# Discovery sources are keyless: Greenhouse / Lever / Ashby public
# board APIs + Reddit's JSON API. You don't need a job-aggregator
# subscription to use JobHunt.
#
# `.env` is gitignored. Never commit your real keys.

# ──────────────────────────────────────────────────────────────────────────────
# AI provider — REQUIRED for resume parsing, fit assessment, trust
# assessment, tailoring, cover letters, and outreach drafting.
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic Claude — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model selection (defaults are sensible; override only if you know why)
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HIGH_STAKES=claude-opus-4-7

# ──────────────────────────────────────────────────────────────────────────────
# Search APIs — OPTIONAL. Used by Phase 6 contact discovery to find
# linkedin.com/in URLs the user clicks manually. JobHunt never fetches
# LinkedIn pages itself (Agent.md § 1).
# Pick ONE if you want this. Brave is cheaper; Serper has higher quotas.
# ──────────────────────────────────────────────────────────────────────────────

# Brave Search (2K calls/mo free)
# https://brave.com/search/api
BRAVE_SEARCH_API_KEY=

# Serper (paid, ~$5 / 1k queries)
# https://serper.dev
SERPER_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Careers-page crawler (Discovery Mode 3, Phase 8) — optional
# Falls back to local Playwright if absent.
# ──────────────────────────────────────────────────────────────────────────────

# Firecrawl (500 pages/mo free)
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Public profile signals (Phase 1) — optional but recommended
# ──────────────────────────────────────────────────────────────────────────────

# GitHub auth token raises rate limit from 60 to 5000 req/hr.
# Needs only the `public_repo` scope.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Server config
# ──────────────────────────────────────────────────────────────────────────────

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Set to 1 only when deploying to a VPS behind Cloudflare Tunnel (or similar).
# When 0, the backend binds to localhost only.
BIND_PUBLIC=0

# CORS origin for the frontend (no trailing slash).
FRONTEND_ORIGIN=http://localhost:3000

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────

DATABASE_URL=sqlite+aiosqlite:///./data/jobhunt.db

# ──────────────────────────────────────────────────────────────────────────────
# Frontend (read at build time by Next.js)
# ──────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
