# JobHunt — environment configuration
#
# Copy this file to `.env` and fill in only the keys for the providers you
# actually want to use. JobHunt is BYO-keys: nothing is shipped with the repo.
#
# All non-Anthropic keys are optional. Pick at least ONE provider per category
# you want to enable (e.g. one job aggregator, one search API). The backend
# detects which keys are present at startup and only enables those providers.
#
# `.env` is gitignored. Never commit your real keys.

# ──────────────────────────────────────────────────────────────────────────────
# AI provider — required once you start using AI features (Phase 1+)
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic Claude — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model selection (defaults are sensible; override only if you know why)
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HIGH_STAKES=claude-opus-4-7

# ──────────────────────────────────────────────────────────────────────────────
# Job aggregators (Discovery Mode 1) — pick at LEAST ONE
# Each works standalone; configure multiple for broader coverage.
# ──────────────────────────────────────────────────────────────────────────────

# JSearch via RapidAPI (global, 150 calls/mo free)
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Adzuna (free tier with attribution; India + US + EU + others)
# https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble (global, generous free tier)
# https://jooble.org/api
JOOBLE_API_KEY=

# TheirStack (paid, structured tech-job data)
# https://theirstack.com
THEIRSTACK_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Search APIs — used for LinkedIn URL discovery + signal aggregation (Phase 6)
# Pick ONE. Brave is cheaper; Serper has higher quotas.
# ──────────────────────────────────────────────────────────────────────────────

# Brave Search (2K calls/mo free)
# https://brave.com/search/api
BRAVE_SEARCH_API_KEY=

# Serper (paid, ~$5 / 1k queries)
# https://serper.dev
SERPER_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Careers-page crawler (Discovery Mode 3, Phase 8) — optional
# Falls back to local Playwright if absent.
# ──────────────────────────────────────────────────────────────────────────────

# Firecrawl (500 pages/mo free)
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Public profile signals (Phase 1) — optional but recommended
# ──────────────────────────────────────────────────────────────────────────────

# GitHub auth token raises rate limit from 60 to 5000 req/hr.
# Needs only the `public_repo` scope.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Server config
# ──────────────────────────────────────────────────────────────────────────────

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Set to 1 only when deploying to a VPS behind Cloudflare Tunnel (or similar).
# When 0, the backend binds to localhost only.
BIND_PUBLIC=0

# CORS origin for the frontend (no trailing slash).
FRONTEND_ORIGIN=http://localhost:3000

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────

DATABASE_URL=sqlite+aiosqlite:///./data/jobhunt.db

# ──────────────────────────────────────────────────────────────────────────────
# Frontend (read at build time by Next.js)
# ──────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
